---
import profileRaw from "../data/profile.json";

const profile = profileRaw as Record<string, any>;
const githubUrl = profile.html_url || "https://github.com/LondheShubham153";
const linkedinUrl = "https://www.linkedin.com/in/shubhamlondhe1996/";
const blog = profile.blog || "";
const twitter = profile.twitter_username || "";
const email = profile.email || "";
---

<section>
  <h2>Contact</h2>
  <ul class="links">
    <li>
      <a href={githubUrl} target="_blank" rel="noopener">GitHub</a>
    </li>
    <li>
      <a href={linkedinUrl} target="_blank" rel="noopener" aria-label="LinkedIn profile">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
        </svg>
        LinkedIn
      </a>
    </li>
    {twitter && (
      <li>
        <a href={`https://twitter.com/${twitter}`} target="_blank" rel="noopener">Twitter / X</a>
      </li>
    )}
    {blog && (
      <li>
        <a href={blog} target="_blank" rel="noopener">Website</a>
      </li>
    )}
    {email && (
      <li>
        <a href={`mailto:${email}`}>Email</a>
      </li>
    )}
  </ul>
</section>

<style>
  .links {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .links svg {
    flex-shrink: 0;
  }
</style>
