---
interface Props {
  name: string;
  description?: string | null;
  url: string;
  language?: string | null;
  stars: number;
  forks: number;
  topics?: string[];
}

const { name, description, url, language, stars, forks, topics = [] } = Astro.props;
---

<a class="card" href={url} target="_blank" rel="noopener">
  <div class="head">
    <h3>{name}</h3>
    <div class="meta">
      {language && <span class="lang">{language}</span>}
      <span class="stars" title="Stars">★ {stars}</span>
      {forks > 0 && <span class="forks" title="Forks">⑂ {forks}</span>}
    </div>
  </div>
  {description && <p class="desc">{description}</p>}
  {topics.length > 0 && (
    <div class="topics">
      {topics.slice(0, 5).map((t) => <span class="topic">{t}</span>)}
    </div>
  )}
</a>

<style>
  .card {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    color: inherit;
    text-decoration: none;
    transition: transform 0.15s ease, border-color 0.15s ease;
    box-shadow: var(--shadow);
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    text-decoration: none;
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  h3 {
    margin: 0;
    font-size: 1.05rem;
    color: var(--accent);
  }
  .meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }
  .lang {
    background: var(--code-bg);
    padding: 0.1em 0.5em;
    border-radius: 4px;
  }
  .desc {
    color: var(--fg-muted);
    margin: 0.5rem 0 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .topics {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }
  .topic {
    font-size: 0.75rem;
    background: var(--code-bg);
    color: var(--fg-muted);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    font-family: var(--font-mono);
  }
</style>
