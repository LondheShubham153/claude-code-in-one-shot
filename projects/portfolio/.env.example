# ngrok auth token — REQUIRED for `docker compose up` to bring up the tunnel.
# Get yours: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# GitHub PAT — OPTIONAL, but raises the build-time API limit from 60/hr to 5000/hr.
# Only needs `public_repo` read scope. Leave blank to use unauthenticated calls.
# Generate one: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
