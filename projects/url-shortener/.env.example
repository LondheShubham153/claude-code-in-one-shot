# Postgres credentials — REQUIRED. Used by the postgres service AND by Temporal
# auto-setup (which creates two extra databases on the same instance).
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=urlshortener_dev_change_me
POSTGRES_DB=urlshortener

# Public URL the app is reached at. Used to build the `short_url` field in API
# responses. REQUIRED. Examples:
#   http://localhost:8081            (local dev via docker compose)
#   https://<random>.ngrok-free.app  (when running with --profile public)
PUBLIC_BASE_URL=http://localhost:8081

# Google Safe Browsing v4 API key — OPTIONAL. When set, every shorten request
# is checked against MALWARE / SOCIAL_ENGINEERING / UNWANTED_SOFTWARE /
# POTENTIALLY_HARMFUL_APPLICATION threat lists, and a daily Temporal cron
# workflow re-checks every stored URL. When unset, both checks no-op (with a
# warning logged at startup). Get a key:
# https://developers.google.com/safe-browsing/v4/get-started
SAFE_BROWSING_API_KEY=

# Per-IP rate limit on POST /api/links. Format: "<count>/<period>" (slowapi).
RATE_LIMIT_SHORTEN=10/minute

# ngrok auth token — REQUIRED only when running with `--profile public`.
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
